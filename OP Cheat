            fuseHighlightEnabled = not fuseHighlightEnabled
            updateFuseHighlights()
            btn.Text = fuseHighlightEnabled and "Desativar Fuse Esp" or "Ativar Fuse Esp"
            print("Fuse Tracker: " .. (fuseHighlightEnabled and "ATIVADO (AUTO)" or "DESATIVADO"))
        else
            teleport(data.name, data.pos)
