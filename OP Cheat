        if data.special == "fuse" then
            teleportToNearestFuse()
        elseif data.special == "animatronics" then
            animatronicHighlightEnabled = not animatronicHighlightEnabled
            updateAnimatronicHighlights()
            btn.Text = animatronicHighlightEnabled and "Desativar Animatronics Esp" or "Ativar Animatronics Esp"
            print("Animatronics Tracker: " .. (animatronicHighlightEnabled and "ATIVADO" or "DESATIVADO"))
