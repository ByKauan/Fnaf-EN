-- ✅ SISTEMA DE HIGHLIGHT ANIMATRONICS
local animatronicHighlightEnabled = false
local animatronicHighlights = {}

local function updateAnimatronicHighlights()
    -- Remove highlights antigos
    for _, highlight in pairs(animatronicHighlights) do
        if highlight and highlight.Parent then
            highlight:Destroy()
        end
    end
    animatronicHighlights = {}
    
    if not animatronicHighlightEnabled then return end
    
    -- Procura animatronics (nomes comuns em FNAF)
    local animatronicNames = {"freddy", "bonnie", "chica", "foxy", "puppet", "golden", "animatronic", "animatron"}
    
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") then
            local found = false
            for _, name in pairs(animatronicNames) do
                if string.find(string.lower(obj.Name), name) then
                    found = true
                    break
                end
            end
            
            if found then
                local highlight = Instance.new("Highlight")
                highlight.Name = "AnimatronicHighlight"
                highlight.Adornee = obj
                highlight.FillColor = Color3.fromRGB(255, 100, 100)
                highlight.OutlineColor = Color3.fromRGB(255, 50, 50)
                highlight.FillTransparency = 0.4
                highlight.OutlineTransparency = 0
                highlight.Parent = obj
                table.insert(animatronicHighlights, highlight)
            end
        end
    end
end

local function updateFuseHighlights()
    -- Remove highlights antigos
    for _, highlight in pairs(fuseHighlights) do
        if highlight and highlight.Parent then
            highlight:Destroy()
        end
    end
    fuseHighlights = {}
    
    if not fuseHighlightEnabled then return end
    
    -- Procura tools "Fuse" no workspace
    for _, obj in pairs(workspace:GetChildren()) do
        if obj:IsA("Tool") and string.find(string.lower(obj.Name), "fuse") then
            local highlight = Instance.new("Highlight")
            highlight.Name = "FuseHighlight"
            highlight.Adornee = obj
            highlight.FillColor = Color3.fromRGB(255, 50, 50)
            highlight.OutlineColor = Color3.fromRGB(255, 255, 50)
            highlight.FillTransparency = 0.3
            highlight.OutlineTransparency = 0
            highlight.Parent = obj
            table.insert(fuseHighlights, highlight)
        end
    end
end

-- ✅ DETECÇÃO AUTOMÁTICA DE FUSEs E ANIMATRONICS
workspace.DescendantAdded:Connect(function(child)
    if fuseHighlightEnabled and child:IsA("Tool") and string.find(string.lower(child.Name), "fuse") then
        wait(0.1)
        updateFuseHighlights()
        print("🔍 Nova Fuse detectada: " .. child.Name)
    end
    
    if animatronicHighlightEnabled and child:IsA("Model") and child:FindFirstChild("Humanoid") then
        local animatronicNames = {"freddy", "bonnie", "chica", "foxy", "puppet", "golden", "animatronic"}
        for _, name in pairs(animatronicNames) do
            if string.find(string.lower(child.Name), name) then
                wait(0.1)
                updateAnimatronicHighlights()
                print("🎭 Novo Animatronic detectado: " .. child.Name)
                break
            end
        end
    end
end)

-- ✅ FUNÇÃO TP FUSE MAIS PRÓXIMO
local function teleportToNearestFuse()
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
        print("❌ Personagem não encontrado!")
        return
    end
    
    local playerPos = player.Character.HumanoidRootPart.Position
    local nearestFuse = nil
    local nearestDistance = math.huge
    
    -- Procura todas as Fuses
    for _, obj in pairs(workspace:GetChildren()) do
        if obj:IsA("Tool") and string.find(string.lower(obj.Name), "fuse") then
            local distance = (obj:GetPivot().Position - playerPos).Magnitude
            if distance < nearestDistance then
                nearestDistance = distance
                nearestFuse = obj
            end
        end
    end
    
    if nearestFuse then
        player.Character.HumanoidRootPart.CFrame = nearestFuse:GetPivot()
        print("✨ Teleportado para Fuse mais próxima (" .. nearestDistance .. " studs): " .. nearestFuse.Name)
    else
        print("❌ Nenhuma Fuse encontrada no workspace!")
    end
end

