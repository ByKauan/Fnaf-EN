    else
        btn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        btn.Text = data.name
    end
    
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextScaled = true
    btn.Font = Enum.Font.GothamBold
    btn.LayoutOrder = i
    btn.Parent = scrollFrame
    
